# Supabase auth — copy this file to ".env" and fill in your project's values.
# Find them in your Supabase dashboard under: Project Settings → API.
#
# Until these are set, EasyPeasy stores accounts on-device (local fallback) so
# login/signup still work for development.
#
# IMPORTANT: For the name + PIN flow, turn OFF email confirmation in Supabase:
#   Authentication → Sign In / Providers → Email → disable "Confirm email"
# (Names are mapped to synthetic emails the learner never sees, so there is no
#  inbox to confirm.)

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
